# aiox-squads-ui — environment variables
#
# Copy this file to `.env` (Next.js loads `.env.local` first, then `.env`)
# and fill in real values. The app runs in stub mode without any of these,
# so you can leave blanks for local UI work.

# ─── Supabase ─────────────────────────────────────────────────────────
# Project Settings → API → URL + anon public key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Project Settings → API → service_role secret (server only — never bundle)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Postgres ─────────────────────────────────────────────────────────
# Project Settings → Database → Connection string (Connection pooling)
# Add `?pgbouncer=true&connection_limit=1` for serverless safety.
DATABASE_URL=

# Direct connection string (used by Prisma migrate). Without pgbouncer.
DIRECT_URL=

# ─── Optional ─────────────────────────────────────────────────────────
# Inngest (F6.4 — async Squad Run orchestration)
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# Sentry (F8 — observability)
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
